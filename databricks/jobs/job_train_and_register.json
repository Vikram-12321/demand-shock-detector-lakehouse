{
  "name": "demand-shock-train-and-register",
  "description": "Train RandomForest model with MLflow logging, then register to Model Registry",
  "email_notifications": {},
  "timeout_seconds": 7200,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "04_train_model_mlflow",
      "description": "Train model and log to MLflow",
      "notebook_task": {
        "notebook_path": "/Repos/<your-username>/demand-shock-detector-lakehouse/databricks/notebooks/04_train_model_mlflow",
        "base_parameters": {}
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true"
        },
        "libraries": [
          { "pypi": { "package": "scikit-learn>=1.5.0" } }
        ]
      },
      "timeout_seconds": 3600
    },
    {
      "task_key": "06_register_model",
      "description": "Register best run to MLflow Model Registry",
      "depends_on": [{ "task_key": "04_train_model_mlflow" }],
      "notebook_task": {
        "notebook_path": "/Repos/<your-username>/demand-shock-detector-lakehouse/databricks/notebooks/06_register_model",
        "base_parameters": {}
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 1
      },
      "timeout_seconds": 600
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 0 4 * * ?",
    "timezone_id": "UTC",
    "pause_status": "PAUSED"
  }
}
