{
  "name": "demand-shock-batch-score",
  "description": "Load registered model and score latest gold features → write predictions",
  "email_notifications": {},
  "timeout_seconds": 3600,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "05_batch_scoring_writeback",
      "description": "Score gold features with Champion model and write to gold_predictions_daily",
      "notebook_task": {
        "notebook_path": "/Repos/<your-username>/demand-shock-detector-lakehouse/databricks/notebooks/05_batch_scoring_writeback",
        "base_parameters": {}
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true"
        },
        "libraries": [
          { "pypi": { "package": "scikit-learn>=1.5.0" } },
          { "pypi": { "package": "mlflow>=2.13.0" } }
        ]
      },
      "timeout_seconds": 3600
    }
  ],
  "schedule": {
    "quartz_cron_expression": "0 30 6 * * ?",
    "timezone_id": "UTC",
    "pause_status": "PAUSED"
  }
}
